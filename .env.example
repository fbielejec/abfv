# abfv local configuration - copy to `.env` and edit for your machine.
# `main` loads `.env` at startup; clap reads these via its `env = ...` args.
# Real environment variables (e.g. those baked into the Docker image) win over
# anything set here.

# Python interpreter for the ABodyBuilder3 worker scripts.
# This is the only host-specific path: the checkpoint and freesasa binary are
# vendored in-repo (vendored/) and use built-in relative defaults. Override
# ABFV_CHECKPOINT / ABFV_FREESASA here only if you keep them elsewhere.
ABFV_PYTHON=/path/to/abodybuilder3/.venv/bin/python